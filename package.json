{
  "name": "sitegeef",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3500",
    "dev:watchdog": "node scripts/dev-watchdog.mjs",
    "agent:lint": "node scripts/agent-lint.mjs",
    "agent:map": "node scripts/generate-agent-map.mjs",
    "build": "next build",
    "test:admin-smoke": "node tests/admin-smoke.mjs",
    "postbuild": "node scripts/copy-standalone-assets.js",
    "start": "node .next/standalone/server.js",
    "start:standalone": "node .next/standalone/server.js",
    "apply-migration": "node scripts/apply-migration.js",
