{
  "name": "sitegeef",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "next dev -p 3500",
    "autoreflex:serve": "node scripts/autoreflex-local.mjs",
    "autoreflex:up": "node scripts/autoreflex-up.mjs",
