    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.4.2",
    "pg": "^8.20.0",
    "supabase": "^2.98.2",
    "typescript": "^5.0.0"
  }
