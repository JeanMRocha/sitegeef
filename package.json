    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "dotenv": "^17.4.2",
    "eslint": "^8.50.0",
    "eslint-config-next": "^15.0.0",
    "eslint-plugin-react": "^7.33.0",
    "pg": "^8.20.0",
    "prettier": "^3.1.0",
    "supabase": "^2.98.2",
    "typescript": "^6.0.3",
    "vitest": "^1.0.0"
